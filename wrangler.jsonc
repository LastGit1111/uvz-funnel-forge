{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "uvz-funnel-forge",
  "compatibility_date": "2024-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": "./dist",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "uvz-funnel-db",
      "database_id": "2b6c8fa2-5ae5-4b55-8dfc-25997b5cdace"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ASSETS_BUCKET",
      "bucket_name": "uvz-funnel-forge-assets"
    }
  ]
}
